# SMFC ERP production deployment settings.
# Copy this file to deploy/production.env on the server and edit before running:
#   ./deploy/bootstrap-prod.sh

# Public hostname that users will open in the browser.
DOMAIN_NAME=erp.example.com
LETSENCRYPT_EMAIL=admin@example.com
ENABLE_SSL=true

# Image/build settings.
IMAGE_TAG=prod
BACKEND_WORKERS=3
RUN_MIGRATIONS=true
RUN_SEED_DATA=true

# Public ports exposed on the host.
HTTP_PORT=80
HTTPS_PORT=443

# Frontend uses same-origin API through Nginx.
VITE_API_URL=/api/v1

# Application settings.
APP_NAME="SMFC ERP"
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=https://erp.example.com

# Database.
POSTGRES_USER=smfc
POSTGRES_PASSWORD=change-me-generate-on-server
POSTGRES_DB=smfc_erp
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis is internal to Docker Compose.
REDIS_URL=redis://redis:6379/0

# JWT secret is also used to derive the app encryption key.
# Do not rotate casually after tenant integration credentials are configured.
JWT_SECRET_KEY=change-me-generate-on-server
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial tenant/admin seed. The seed is idempotent; change these before first run.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_FULL_NAME="System Administrator"
SEED_ADMIN_PASSWORD=change-me-generate-on-server

# Security defaults.
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
PASSWORD_EXPIRY_DAYS=90

# Email is disabled by default for manual-first rollout.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="SMFC ERP"
SMTP_USE_TLS=true

# Nginx upload cap for DMS, portal uploads, and report downloads.
NGINX_CLIENT_MAX_BODY_SIZE=50m

# Optional local services.
ENABLE_CLAMAV=false
INSTALL_SSL_RENEWAL_CRON=true
