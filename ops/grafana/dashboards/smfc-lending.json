{
  "__schema": "Grafana dashboard JSON — lending-specific domain metrics. STAGE-6-PENDING-grafana-dashboards closure.",
  "title": "SMFC Lending — AUM, NPA, collections, queue lag",
  "uid": "smfc-lending",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "Asia/Kolkata",
  "tags": ["smfc", "lending", "nbfc"],
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "query": "local,staging,production",
        "current": { "text": "production", "value": "production" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total AUM (₹)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [{ "expr": "sum(lending_outstanding_principal_rupees{env=\"$env\"})", "legendFormat": "AUM" }],
      "fieldConfig": { "defaults": { "unit": "currencyINR" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active loan accounts",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [{ "expr": "sum(lending_active_accounts{env=\"$env\"})" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Gross NPA %",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        {
          "expr": "100 * sum(lending_outstanding_principal_rupees{env=\"$env\",classification=~\"substandard|doubtful_1|doubtful_2|doubtful_3|loss\"}) / sum(lending_outstanding_principal_rupees{env=\"$env\"})",
          "legendFormat": "GNPA"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 6 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Collection efficiency (30d)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        {
          "expr": "100 * sum(increase(lending_receipts_rupees_total{env=\"$env\"}[30d])) / sum(increase(lending_demand_rupees_total{env=\"$env\"}[30d]))",
          "legendFormat": "CE%"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Accounts by NPA bucket (count)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        {
          "expr": "sum by (classification) (lending_accounts_by_classification{env=\"$env\"})",
          "legendFormat": "{{classification}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "DPD distribution (0–30, 31–60, 61–90, 91+)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        {
          "expr": "sum by (dpd_bucket) (lending_accounts_by_dpd_bucket{env=\"$env\"})",
          "legendFormat": "{{dpd_bucket}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Arq NPA-reclassification job lag",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        {
          "expr": "arq_job_duration_seconds{env=\"$env\", function=\"reclassify_npa_batch\"}",
          "legendFormat": "seconds"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Payroll batch completion (processed vs pending)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        {
          "expr": "payroll_payslips_processed_total{env=\"$env\"}",
          "legendFormat": "processed"
        },
        {
          "expr": "payroll_payslips_pending_total{env=\"$env\"}",
          "legendFormat": "pending"
        }
      ]
    }
  ]
}
