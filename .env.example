# Frontend environment example. Copy to `.env` (or pass at build time).
#
# Only public, non-secret values go here — they end up in the JS bundle.
# Real secrets live on the backend / in IntegrationConfig per §6.8.

# Backend API base URL.
# Local dev:  http://localhost:8001/api/v1
# Staging:    https://staging-api.smfc.example/api/v1
# Production: https://api.smfc.example/api/v1
VITE_API_URL=http://localhost:8001/api/v1

